# Copy this file to .env and fill local runtime credentials.

# OpenAI-compatible provider used in the first milestone.
# Example providers: DeepSeek, Kimi, GLM-compatible gateway, local gateway.
CODEMATE_PROVIDER=deepseek
CODEMATE_MODEL=deepseek-chat
CODEMATE_BASE_URL=https://api.deepseek.com/v1
CODEMATE_API_KEY=your-credential

# Runtime options
CODEMATE_PROJECT_CONTEXT=CODEMATE.md
CODEMATE_MAX_AGENT_STEPS=8

# For named, switchable model profiles, run /model init after starting codeMate.
# The local .codemate/models.properties file is ignored by Git.
